{"type":"item.started","item":{"id":"item_28","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\nsource .venv/bin/activate\npython - << 'PY'\nimport arxiv, json\nqueries = [\n    'all:\\\"chain of thought\\\" AND cat:cs.CL',\n    'all:\\\"deliberate\\\" AND all:\\\"large language models\\\" AND cat:cs.CL',\n    'all:\\\"reasoning\\\" AND all:\\\"language models\\\" AND cat:cs.CL',\n    'all:\\\"process supervision\\\" AND all:\\\"language models\\\"',\n    'all:\\\"think before speaking\\\" AND all:\\\"language model\\\"',\n]\nseen = {}\nfor q in queries:\n    search = arxiv.Search(query=q, max_results=15, sort_by=arxiv.SortCriterion.Relevance)\n    for r in search.results():\n        aid = r.get_short_id().split('v')[0]\n        if aid in seen:\n            continue\n        seen[aid] = {\n            'id': aid,\n            'title': r.title.strip().replace('\\\\n',' '),\n            'year': r.published.year,\n            'authors': ', '.join(a.name for a in r.authors[:8]),\n            'pdf_url': r.pdf_url,\n            'entry_id': r.entry_id,\n            'summary': ' '.join(r.summary.split())[:500]\n        }\nprint('candidates', len(seen))\nwith open('arxiv_candidates.json','w') as f:\n    json.dump(list(seen.values()), f, indent=2)\nprint('saved arxiv_candidates.json')\nPY\npython - << 'PY'\nimport json\ncand=json.load(open('arxiv_candidates.json'))\nfor p in sorted(cand, key=lambda x:(-x['year'], x['title']))[:25]:\n    print(f\\\"{p['year']}\\\\t{p['id']}\\\\t{p['title'][:110]}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
