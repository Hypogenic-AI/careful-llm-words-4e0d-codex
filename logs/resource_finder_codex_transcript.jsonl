{"type":"item.started","item":{"id":"item_60","type":"command_execution","command":"/usr/bin/bash -lc \"source .venv/bin/activate\npython - << 'PY'\nimport requests, json\nqueries=['chain of thought prompting language models','think before you speak language models inner monologue','quiet-star think before speaking']\nrows=[]\nfor q in queries:\n    url='https://api.semanticscholar.org/graph/v1/paper/search'\n    params={'query':q,'limit':5,'fields':'title,year,citationCount,url,authors'}\n    r=requests.get(url,params=params,timeout=30)\n    rows.append({'query':q,'status':r.status_code,'results':[]})\n    if r.ok:\n        data=r.json().get('data',[])\n        for p in data:\n            rows[-1]['results'].append({\n                'title':p.get('title'),\n                'year':p.get('year'),\n                'citations':p.get('citationCount'),\n                'url':p.get('url')\n            })\nprint(json.dumps(rows,indent=2)[:8000])\nopen('semantic_scholar_search.json','w').write(json.dumps(rows,indent=2))\n\n# paperswithcode quick query pages\nimport urllib.parse\npwq=['chain of thought','tree of thoughts','truthfulqa']\npw=[]\nfor q in pwq:\n    u='https://paperswithcode.com/search?q='+urllib.parse.quote(q)\n    rr=requests.get(u,timeout=30)\n    pw.append({'query':q,'url':u,'status':rr.status_code,'title_present':'<title>' in rr.text})\nopen('paperswithcode_search.json','w').write(json.dumps(pw,indent=2))\nprint('\\\\nPWC:',json.dumps(pw,indent=2))\nPY\nls -lh semantic_scholar_search.json paperswithcode_search.json\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
