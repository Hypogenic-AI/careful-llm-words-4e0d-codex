{"type":"item.started","item":{"id":"item_53","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\ncat > datasets/.gitignore << 'EOF'\n# Exclude all data files (can be large)\n*\n\n# But include documentation and small samples\n\"'!.gitignore\n!README.md\n!**/README.md\n!**/samples/\n!**/download.sh\n!**/download_instructions.txt\n!**/*.json\n!**/*.jsonl\nEOF\nsource .venv/bin/activate\npython - << '\"'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\n\nbase=Path('datasets')\n(base/'truthful_qa').mkdir(parents=True, exist_ok=True)\n(base/'gsm8k').mkdir(parents=True, exist_ok=True)\n(base/'real_toxicity_prompts').mkdir(parents=True, exist_ok=True)\n\nsummary=[]\n\n# TruthfulQA\ntruth = load_dataset('truthful_qa', 'generation')\ntruth.save_to_disk(str(base/'truthful_qa'/'hf'))\nsample_truth = truth['validation'][:10]\n(base/'truthful_qa'/'samples').mkdir(exist_ok=True)\nwith open(base/'truthful_qa'/'samples'/'samples.json','w') as f:\n    json.dump(sample_truth, f, indent=2)\nsummary.append({'name':'truthful_qa:generation','splits':{k:len(v) for k,v in truth.items()},'location':'datasets/truthful_qa/hf'})\n\n# GSM8K\ngsm = load_dataset('gsm8k', 'main')\ngsm.save_to_disk(str(base/'gsm8k'/'hf'))\n(base/'gsm8k'/'samples').mkdir(exist_ok=True)\nwith open(base/'gsm8k'/'samples'/'samples.json','w') as f:\n    json.dump(gsm['train'][:10], f, indent=2)\nsummary.append({'name':'gsm8k:main','splits':{k:len(v) for k,v in gsm.items()},'location':'datasets/gsm8k/hf'})\n\n# Real Toxicity Prompts (subset for local speed)\nrtp = load_dataset('allenai/real-toxicity-prompts')\n# keep subset of train for local experimentation footprint\nsubset = rtp['train'].select(range(min(20000, len(rtp['train']))))\nsubset.save_to_disk(str(base/'real_toxicity_prompts'/'hf_train20k'))\n(base/'real_toxicity_prompts'/'samples').mkdir(exist_ok=True)\nwith open(base/'real_toxicity_prompts'/'samples'/'samples.json','w') as f:\n    json.dump(subset[:10], f, indent=2)\